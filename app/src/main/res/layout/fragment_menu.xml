<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0F"
    android:fillViewport="true"
    android:fadeScrollbars="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="24dp"
        android:paddingBottom="16dp">

        <!-- Greeting Section -->
        <TextView
            android:id="@+id/txtOla"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ola, Atleta!"
            android:textColor="#E8E8F0"
            android:textSize="24sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/txtInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pronto para treinar hoje?"
            android:textColor="#8888A0"
            android:textSize="14sp"
            android:layout_marginBottom="16dp" />

        <!-- Info Chips Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <TextView
                android:id="@+id/chipPeso"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:background="@drawable/bg_chip"
                android:gravity="center"
                android:text="Peso: --"
                android:textColor="#E8E8F0"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/chipImc"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:background="@drawable/bg_chip"
                android:gravity="center"
                android:text="IMC: --"
                android:textColor="#E8E8F0"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/chipObjetivo"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:background="@drawable/bg_chip"
                android:gravity="center"
                android:text="Objetivo"
                android:textColor="#E8E8F0"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Hero Workout Card -->
        <FrameLayout
            android:id="@+id/cardHero"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_header_gradient"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TREINO DE HOJE"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/txtDiaTreino"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Segunda-feira"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:alpha="0.85"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/txtGruposMusculares"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Peito, Triceps"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:alpha="0.7"
                    android:layout_marginBottom="20dp" />

                <Button
                    android:id="@+id/btnComecarTreino"
                    android:layout_width="160dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_btn"
                    android:text="COMECAR"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />
            </LinearLayout>
        </FrameLayout>

        <!-- Feature Grid -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <!-- Assistente IA -->
            <LinearLayout
                android:id="@+id/cardAssistente"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingVertical="20dp"
                android:layout_marginEnd="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&#x1F916;"
                    android:textSize="28sp"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Assistente IA"
                    android:textColor="#E8E8F0"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:gravity="center" />
            </LinearLayout>

            <!-- Timer -->
            <LinearLayout
                android:id="@+id/cardTimer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingVertical="20dp"
                android:layout_marginStart="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&#x23F1;"
                    android:textSize="28sp"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Timer"
                    android:textColor="#E8E8F0"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:gravity="center" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <!-- Historico -->
            <LinearLayout
                android:id="@+id/cardHistorico"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingVertical="20dp"
                android:layout_marginEnd="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&#x1F4CB;"
                    android:textSize="28sp"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Historico"
                    android:textColor="#E8E8F0"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:gravity="center" />
            </LinearLayout>

            <!-- Evolucao -->
            <LinearLayout
                android:id="@+id/cardEvolucao"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingVertical="20dp"
                android:layout_marginStart="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&#x1F4C8;"
                    android:textSize="28sp"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Evolucao"
                    android:textColor="#E8E8F0"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:gravity="center" />
            </LinearLayout>
        </LinearLayout>

        <!-- Menu Options -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="OPCOES"
            android:textColor="#8888A0"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.15"
            android:layout_marginBottom="12dp" />

        <!-- Treino da semana -->
        <LinearLayout
            android:id="@+id/btnTreinoSemana"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_card"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="&#x1F4C5;  Treino da semana"
                android:textColor="#E8E8F0"
                android:textSize="15sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=">"
                android:textColor="#8888A0"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Registrar peso -->
        <LinearLayout
            android:id="@+id/btnRegistrarPeso"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_card"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="&#x2696;  Registrar peso"
                android:textColor="#E8E8F0"
                android:textSize="15sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=">"
                android:textColor="#8888A0"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Ver IMC -->
        <LinearLayout
            android:id="@+id/btnVerImc"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_card"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="&#x1F4CA;  Ver IMC"
                android:textColor="#E8E8F0"
                android:textSize="15sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=">"
                android:textColor="#8888A0"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Atualizar perfil -->
        <LinearLayout
            android:id="@+id/btnAtualizarPerfil"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_card"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="&#x2699;  Atualizar perfil"
                android:textColor="#E8E8F0"
                android:textSize="15sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=">"
                android:textColor="#8888A0"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
