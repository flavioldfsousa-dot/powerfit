<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0F"
    android:orientation="vertical">

    <include layout="@layout/layout_header" />

    <!-- Chat Area -->
    <ScrollView
        android:id="@+id/scrollChat"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:fadeScrollbars="true"
        android:scrollbars="none"
        android:paddingHorizontal="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <LinearLayout
            android:id="@+id/containerChat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </ScrollView>

    <!-- Input Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_card"
        android:paddingHorizontal="12dp"
        android:paddingVertical="10dp"
        android:layout_marginTop="4dp">

        <EditText
            android:id="@+id/inputMensagem"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/bg_input"
            android:hint="@string/hint_assistant"
            android:textColor="#E8E8F0"
            android:textColorHint="#8888A0"
            android:textSize="14sp"
            android:paddingHorizontal="16dp"
            android:inputType="text"
            android:singleLine="true"
            android:imeOptions="actionSend"
            android:layout_marginEnd="10dp" />

        <Button
            android:id="@+id/btnEnviar"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_btn_accent"
            android:text=">"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>
