<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0F"
    android:fillViewport="true"
    android:fadeScrollbars="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingHorizontal="28dp"
        android:paddingTop="60dp"
        android:paddingBottom="32dp">

        <!-- Logo -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Z"
            android:textColor="#FF2D55"
            android:textSize="48sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-black"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ZENTROX FIT"
            android:textColor="#E8E8F0"
            android:textSize="28sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Comece sua transformacao"
            android:textColor="#8888A0"
            android:textSize="14sp"
            android:layout_marginBottom="36dp" />

        <!-- Name Input -->
        <EditText
            android:id="@+id/inputNome"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_input"
            android:hint="Seu nome"
            android:textColor="#E8E8F0"
            android:textColorHint="#8888A0"
            android:textSize="15sp"
            android:paddingHorizontal="16dp"
            android:inputType="textPersonName"
            android:layout_marginBottom="14dp" />

        <!-- Weight Input -->
        <EditText
            android:id="@+id/inputPeso"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_input"
            android:hint="Peso (kg)"
            android:textColor="#E8E8F0"
            android:textColorHint="#8888A0"
            android:textSize="15sp"
            android:paddingHorizontal="16dp"
            android:inputType="numberDecimal"
            android:layout_marginBottom="14dp" />

        <!-- Height Input -->
        <EditText
            android:id="@+id/inputAltura"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_input"
            android:hint="Altura (m) ex: 1.65"
            android:textColor="#E8E8F0"
            android:textColorHint="#8888A0"
            android:textSize="15sp"
            android:paddingHorizontal="16dp"
            android:inputType="numberDecimal"
            android:layout_marginBottom="14dp" />

        <!-- Objective Label -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Objetivo"
            android:textColor="#8888A0"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp"
            android:layout_marginTop="4dp" />

        <!-- Spinner -->
        <Spinner
            android:id="@+id/spinnerObjetivo"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_input"
            android:layout_marginBottom="28dp" />

        <!-- CTA Button -->
        <Button
            android:id="@+id/btnSalvar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_btn_accent"
            android:text="COMEÇAR"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:letterSpacing="0.08" />

    </LinearLayout>
</ScrollView>
