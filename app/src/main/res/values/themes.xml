<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.ZentroxFit" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/titulo</item>
        <item name="colorPrimaryVariant">@color/titulo</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/accent</item>
        <item name="colorSecondaryVariant">@color/accent2</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:statusBarColor">@color/bg</item>
        <item name="android:navigationBarColor">@color/bg</item>
        <item name="android:windowBackground">@color/bg</item>
        <item name="android:windowAnimationStyle">@style/WindowAnimationTransition</item>
    </style>

    <style name="Theme.ZentroxFit.Splash" parent="Theme.Material3.Dark.NoActionBar">
        <item name="android:windowBackground">@color/splash_bg</item>
        <item name="android:statusBarColor">@color/splash_bg</item>
        <item name="android:navigationBarColor">@color/splash_bg</item>
    </style>

    <style name="WindowAnimationTransition" parent="@android:style/Animation.Activity">
        <item name="android:activityOpenEnterAnimation">@anim/slide_in_right</item>
        <item name="android:activityCloseExitAnimation">@anim/slide_out_left</item>
    </style>
</resources>
